{
  "ConnectionStrings": {
    "ControlSparkUserContextConnection": "Data Source=../data/sqlite/ControlSparkUser.db;Mode=ReadWriteCreate",
    "InquirySparkConnection": "Data Source=../data/sqlite/InquirySpark.db;Mode=ReadOnly"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "System": "Information",
      "Microsoft": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information",
      "InquirySpark.Repository.Services.UnifiedWeb": "Debug",
      "InquirySpark.Web": "Debug"
    }
  },
  "DecisionSpecs": {
    "RootPath": "C:\\websites\\InquirySpark\\DecisionSpecs",
    "LegacyConfigPath": "C:\\websites\\InquirySpark\\configurations\\DecisionSpecs",
    "SoftDeleteRetentionDays": 30,
    "IndexFileName": "DecisionSpecIndex.json"
  },
  "ConversationStorage": {
    "Path": "C:\\websites\\InquirySpark\\conversations"
  },
  "UnifiedWeb": {
    "CapabilityCompletion": {
      "EnablePhaseOverride": true,
      "ForceCompletionCheck": false
    },
    "Migration": {
      "EnableLegacyFallback": true,
      "LegacyReadTimeoutSeconds": 5,
      "DryRunMode": true
    }
  },
  "PerformanceInstrumentation": {
    "Enabled": true,
    "SlowRequestThresholdMs": 2000,
    "TrackKeyActions": true,
    "KeyActions": [
      "Unified/Operations/Index",
      "Unified/DecisionConversation/Index",
      "Unified/DecisionSpecification/Index",
      "Unified/InquiryAdministration/Index",
      "Unified/InquiryAuthoring/Index",
      "Unified/InquiryOperations/Index"
    ],
    "LogToConsole": true,
    "WarningThresholdMs": 1000
  }
}
