@{
    ViewData["Title"] = "My Conversation Sessions";
}

<div class="card border-0 shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h2 class="mb-0"><i class="bi bi-clock-history"></i> My Conversation Sessions</h2>
        <a asp-action="Index" class="btn btn-light btn-sm">
            <i class="bi bi-list"></i> All Specs
        </a>
    </div>
    <div class="card-body">
        <div class="alert alert-info" role="alert">
            <i class="bi bi-info-circle"></i>
            Conversation sessions are managed in your browser session. Full server-side persistence is available in a future release.
        </div>
        <div id="session-list" class="list-group">
            <div class="list-group-item text-muted">
                <i class="bi bi-chat-dots"></i> No saved sessions found. Start a conversation from the 
                <a asp-action="Index">Specs list</a>.
            </div>
        </div>
    </div>
    <div class="card-footer text-muted">
        <i class="bi bi-info-circle"></i> Sessions are stored in browser session storage.
    </div>
</div>
