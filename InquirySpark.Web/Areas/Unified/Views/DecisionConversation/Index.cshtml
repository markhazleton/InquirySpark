@using InquirySpark.Common.Persistence.Repositories
@model IEnumerable<DecisionSpecSummary>
@{
    ViewData["Title"] = "Decision Conversations";
}

<div class="card border-0 shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h2 class="mb-0"><i class="bi bi-chat-dots"></i> Decision Conversations</h2>
        <a asp-action="Sessions" class="btn btn-light btn-sm">
            <i class="bi bi-clock-history"></i> My Sessions
        </a>
    </div>
    <div class="card-body border-bottom">
        <p class="text-white-50 mb-0" style="color: inherit !important">
            <i class="bi bi-info-circle"></i>
            Select a decision specification below to start an AI-guided conversation that collects answers and recommends the best outcome.
        </p>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-chat-dots display-3 d-block mb-3"></i>
                <p class="mb-2 fw-semibold">No decision specifications available.</p>
                <p class="small">Ask a spec author to publish a specification before starting a conversation.</p>
                <a asp-area="Unified" asp-controller="DecisionSpecification" asp-action="Index" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-file-earmark-text"></i> View Specifications
                </a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th scope="col"><i class="bi bi-key"></i> Spec ID</th>
                            <th scope="col"><i class="bi bi-card-heading"></i> Name</th>
                            <th scope="col"><i class="bi bi-circle-half"></i> Status</th>
                            <th scope="col"><i class="bi bi-person"></i> Owner</th>
                            <th scope="col"><i class="bi bi-list-ul"></i> Traits</th>
                            <th scope="col"><i class="bi bi-clock"></i> Updated</th>
                            <th scope="col" class="no-sort">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><code>@item.SpecId</code></td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.Name))
                                    {
                                        @item.Name
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">@item.SpecId</span>
                                    }
                                </td>
                                <td>
                                    @{
                                        var badgeClass = item.Status switch
                                        {
                                            "Published" => "bg-success",
                                            "InReview"  => "bg-warning text-dark",
                                            "Retired"   => "bg-secondary",
                                            _           => "bg-primary"
                                        };
                                    }
                                    <span class="badge @badgeClass">@item.Status</span>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.Owner))
                                    {
                                        @item.Owner
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">—</span>
                                    }
                                </td>
                                <td><span class="badge bg-light text-dark border">@item.TraitCount</span></td>
                                <td class="text-muted small">@item.UpdatedAt.ToString("yyyy-MM-dd")</td>
                                <td>
                                    <a asp-action="Start" asp-route-specId="@item.SpecId"
                                       class="btn btn-sm btn-outline-primary" title="Start Conversation">
                                        <i class="bi bi-play-circle"></i> Start
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
    <div class="card-footer text-muted d-flex justify-content-between align-items-center">
        <span><i class="bi bi-info-circle"></i> Total: @Model.Count() decision specs</span>
        <span><i class="bi bi-lightning"></i> DataTables enabled</span>
    </div>
</div>
