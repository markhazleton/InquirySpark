@model List<InquirySpark.Repository.Database.LuSurveyType>
@{
    ViewData["Title"] = "Survey Types";
}

<div class="card border-0 shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h2 class="mb-0"><i class="bi bi-journal-text"></i> Survey Types</h2>
        <span class="badge bg-light text-primary">@Model.Count types</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th><i class="bi bi-hash"></i> ID</th>
                        <th><i class="bi bi-tag"></i> Short Name</th>
                        <th><i class="bi bi-journals"></i> Name</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.SurveyTypeId</td>
                            <td><span class="badge bg-secondary">@item.SurveyTypeShortNm</span></td>
                            <td><strong>@item.SurveyTypeNm</strong></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer text-muted d-flex justify-content-between align-items-center">
        <span><i class="bi bi-info-circle"></i> Total: @Model.Count records</span>
        <span><i class="bi bi-lightning"></i> DataTables enabled</span>
    </div>
</div>
