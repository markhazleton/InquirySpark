@model List<InquirySpark.Repository.Models.Charting.ChartDefinitionDto>
@{
    ViewData["Title"] = "Chart Builder";
}

<div class="card border-0 shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h2 class="mb-0"><i class="bi bi-bar-chart-line"></i> Chart Builder</h2>
        <span class="badge bg-light text-primary">@Model.Count definitions</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th><i class="bi bi-hash"></i> ID</th>
                        <th><i class="bi bi-bar-chart"></i> Name</th>
                        <th><i class="bi bi-text-paragraph"></i> Description</th>
                        <th><i class="bi bi-tags"></i> Tags</th>
                        <th><i class="bi bi-layers"></i> Version</th>
                        <th><i class="bi bi-calendar"></i> Modified</th>
                        <th><i class="bi bi-toggle-on"></i> Active</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.ChartDefinitionId</td>
                            <td><strong>@item.Name</strong></td>
                            <td><span class="text-muted small">@item.Description</span></td>
                            <td><span class="badge bg-secondary">@item.Tags</span></td>
                            <td>v@item.VersionNumber</td>
                            <td>@item.ModifiedDt.ToString("yyyy-MM-dd")</td>
                            <td>
                                @if (!item.IsArchivedFl)
                                {
                                    <span class="badge bg-success"><i class="bi bi-check"></i> Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary"><i class="bi bi-archive"></i> Archived</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer text-muted d-flex justify-content-between align-items-center">
        <span><i class="bi bi-info-circle"></i> Total: @Model.Count chart definitions</span>
        <span><i class="bi bi-lightning"></i> DataTables enabled</span>
    </div>
</div>
