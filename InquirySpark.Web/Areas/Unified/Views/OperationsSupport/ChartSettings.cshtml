@model List<InquirySpark.Repository.Database.ChartSetting>
@{
    ViewData["Title"] = "Chart Settings";
}

<div class="card border-0 shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h2 class="mb-0"><i class="bi bi-gear"></i> Chart Settings</h2>
        <span class="badge bg-light text-primary">@Model.Count settings</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th><i class="bi bi-hash"></i> ID</th>
                        <th><i class="bi bi-person"></i> Site User</th>
                        <th><i class="bi bi-app"></i> Site App</th>
                        <th><i class="bi bi-tag"></i> Setting Type</th>
                        <th><i class="bi bi-card-text"></i> Setting Name</th>
                        <th><i class="bi bi-pencil"></i> Setting Value</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.SiteUserId</td>
                            <td>@item.SiteAppId</td>
                            <td><span class="badge bg-info text-dark">@item.SettingType</span></td>
                            <td><strong>@item.SettingName</strong></td>
                            <td><span class="text-muted small text-truncate d-inline-block" style="max-width:200px;">@item.SettingValue</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer text-muted d-flex justify-content-between align-items-center">
        <span><i class="bi bi-info-circle"></i> Total: @Model.Count settings</span>
        <span><i class="bi bi-lightning"></i> DataTables enabled</span>
    </div>
</div>
