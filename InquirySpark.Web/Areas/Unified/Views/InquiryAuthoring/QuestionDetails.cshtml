@model InquirySpark.Repository.Database.Question
@{
    ViewData["Title"] = $"Question — {Model.QuestionNm}";
}

<div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h2 class="mb-0"><i class="bi bi-question-circle"></i> @Model.QuestionNm</h2>
        <span class="badge bg-light text-primary">@Model.QuestionType?.QuestionTypeCd</span>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Question ID</dt>
            <dd class="col-sm-9">@Model.QuestionId</dd>
            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.QuestionNm</dd>
            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@Model.QuestionDs</dd>
            <dt class="col-sm-3">Type</dt>
            <dd class="col-sm-9">@Model.QuestionType?.QuestionTypeCd — @Model.QuestionType?.QuestionTypeDs</dd>
        </dl>

        @if (Model.QuestionAnswers?.Any() == true)
        {
            <h5 class="mt-3"><i class="bi bi-list-check"></i> Answers (@Model.QuestionAnswers.Count)</h5>
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Sort</th>
                            <th>Short Name</th>
                            <th>Name</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var answer in Model.QuestionAnswers.OrderBy(a => a.QuestionAnswerSort))
                        {
                            <tr>
                                <td>@answer.QuestionAnswerSort</td>
                                <td><code>@answer.QuestionAnswerShortNm</code></td>
                                <td>@answer.QuestionAnswerNm</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
    <div class="card-footer">
        <a asp-action="Questions" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Back to Questions
        </a>
    </div>
</div>
