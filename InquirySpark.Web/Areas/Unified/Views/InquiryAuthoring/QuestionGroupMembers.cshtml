@model List<InquirySpark.Repository.Database.QuestionGroupMember>
@{
    ViewData["Title"] = "Question Group Members";
}

<div class="card border-0 shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h2 class="mb-0"><i class="bi bi-list-nested"></i> Question Group Members</h2>
        <span class="badge bg-light text-primary">@Model.Count members</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th><i class="bi bi-hash"></i> ID</th>
                        <th><i class="bi bi-collection"></i> Group</th>
                        <th><i class="bi bi-question-circle"></i> Question</th>
                        <th><i class="bi bi-bar-chart"></i> Weight</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.QuestionGroupMemberId</td>
                            <td>@(item.QuestionGroup?.QuestionGroupNm ?? item.QuestionGroupId.ToString())</td>
                            <td>@(item.Question?.QuestionNm ?? item.QuestionId.ToString())</td>
                            <td>@item.QuestionWeight</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer text-muted d-flex justify-content-between align-items-center">
        <span><i class="bi bi-info-circle"></i> Total: @Model.Count members</span>
        <span><i class="bi bi-lightning"></i> DataTables enabled</span>
    </div>
</div>
