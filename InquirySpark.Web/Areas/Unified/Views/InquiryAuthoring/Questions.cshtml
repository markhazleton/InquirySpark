@model List<InquirySpark.Repository.Database.Question>
@{
    ViewData["Title"] = "Questions";
}

<div class="card border-0 shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h2 class="mb-0"><i class="bi bi-question-circle"></i> Questions</h2>
        <span class="badge bg-light text-primary">@Model.Count questions</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th><i class="bi bi-hash"></i> ID</th>
                        <th><i class="bi bi-question-circle"></i> Name</th>
                        <th><i class="bi bi-text-paragraph"></i> Description</th>
                        <th><i class="bi bi-tag"></i> Type</th>
                        <th class="no-sort">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.QuestionId</td>
                            <td><strong>@item.QuestionNm</strong></td>
                            <td><span class="text-muted small text-truncate d-inline-block" style="max-width:250px;">@item.QuestionDs</span></td>
                            <td>@item.QuestionType?.QuestionTypeCd</td>
                            <td>
                                <a asp-action="QuestionDetails" asp-route-id="@item.QuestionId" class="btn btn-sm btn-outline-info" title="Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer text-muted d-flex justify-content-between align-items-center">
        <span><i class="bi bi-info-circle"></i> Total: @Model.Count questions</span>
        <span><i class="bi bi-lightning"></i> DataTables enabled</span>
    </div>
</div>
