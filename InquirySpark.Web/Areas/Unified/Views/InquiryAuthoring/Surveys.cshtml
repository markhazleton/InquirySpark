@model List<InquirySpark.Repository.Database.Survey>
@{
    ViewData["Title"] = "Surveys";
}

<div class="card border-0 shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h2 class="mb-0"><i class="bi bi-journal-check"></i> Surveys</h2>
        <span class="badge bg-light text-primary">@Model.Count surveys</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th><i class="bi bi-hash"></i> ID</th>
                        <th><i class="bi bi-journal"></i> Name</th>
                        <th><i class="bi bi-tag"></i> Short Name</th>
                        <th><i class="bi bi-diagram-3"></i> Type</th>
                        <th><i class="bi bi-collection"></i> Groups</th>
                        <th><i class="bi bi-calendar"></i> Modified</th>
                        <th class="no-sort">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.SurveyId</td>
                            <td><strong>@item.SurveyNm</strong></td>
                            <td><span class="badge bg-secondary">@item.SurveyShortNm</span></td>
                            <td>@item.SurveyType?.SurveyTypeNm</td>
                            <td>@(item.UseQuestionGroupsFl ? "Yes" : "No")</td>
                            <td>@item.ModifiedDt.ToString("yyyy-MM-dd")</td>
                            <td>
                                <a asp-action="SurveyDetails" asp-route-id="@item.SurveyId" class="btn btn-sm btn-outline-info" title="Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer text-muted d-flex justify-content-between align-items-center">
        <span><i class="bi bi-info-circle"></i> Total: @Model.Count surveys</span>
        <span><i class="bi bi-lightning"></i> DataTables enabled</span>
    </div>
</div>
