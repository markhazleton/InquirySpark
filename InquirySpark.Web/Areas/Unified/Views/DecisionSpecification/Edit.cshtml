@model InquirySpark.Common.Models.Spec.DecisionSpecDocument
@{
    ViewData["Title"] = $"Edit — {Model.Metadata?.Name ?? Model.SpecId}";
    var etag = ViewData["ETag"] as string ?? "";
}

<div class="card border-0 shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h2 class="mb-0"><i class="bi bi-pencil"></i> Edit Specification</h2>
        <span class="badge bg-light text-primary"><code>@Model.SpecId</code></span>
    </div>
    <div class="card-body">
        <form asp-action="Edit" asp-route-specId="@Model.SpecId" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="eTag" value="@etag" />

            <!-- Core fields -->
            <h6 class="text-muted text-uppercase small fw-semibold mb-3 mt-1">
                <i class="bi bi-gear"></i> Core Fields
            </h6>
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label asp-for="SpecId" class="form-label fw-semibold">Spec ID</label>
                    <input asp-for="SpecId" class="form-control" readonly />
                </div>
                <div class="col-md-3">
                    <label asp-for="Version" class="form-label fw-semibold">Version</label>
                    <input asp-for="Version" class="form-control" />
                    <span asp-validation-for="Version" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Status" class="form-label fw-semibold">Status</label>
                    <select asp-for="Status" class="form-select">
                        <option value="Draft">Draft</option>
                        <option value="InReview">In Review</option>
                        <option value="Published">Published</option>
                        <option value="Retired">Retired</option>
                    </select>
                </div>
                <div class="col-12">
                    <label asp-for="CanonicalBaseUrl" class="form-label fw-semibold">Canonical Base URL</label>
                    <input asp-for="CanonicalBaseUrl" class="form-control" />
                    <span asp-validation-for="CanonicalBaseUrl" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="SafetyPreamble" class="form-label fw-semibold">Safety Preamble</label>
                    <textarea asp-for="SafetyPreamble" class="form-control" rows="2"></textarea>
                </div>
            </div>

            <!-- Metadata fields -->
            <h6 class="text-muted text-uppercase small fw-semibold mb-3 border-top pt-3">
                <i class="bi bi-card-text"></i> Metadata
            </h6>
            <div class="row g-3 mb-4">
                <div class="col-md-8">
                    <label class="form-label fw-semibold">Name</label>
                    <input name="Metadata.Name" class="form-control"
                           value="@(Model.Metadata?.Name ?? string.Empty)"
                           placeholder="Human-readable specification name" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Owner</label>
                    <input name="Metadata.Owner" class="form-control"
                           value="@(Model.Metadata?.Owner ?? string.Empty)"
                           placeholder="Owner or team name" />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Description</label>
                    <textarea name="Metadata.Description" class="form-control" rows="2"
                              placeholder="Brief description of this specification's purpose">@(Model.Metadata?.Description ?? string.Empty)</textarea>
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Tags <span class="text-muted fw-normal">(comma-separated)</span></label>
                    <input name="Metadata.TagsRaw" class="form-control"
                           value="@(Model.Metadata?.Tags is { Count: > 0 } tags ? string.Join(", ", tags) : string.Empty)"
                           placeholder="e.g. clinical, triage, urgent-care" />
                    <div class="form-text">Tags help categorise and search specifications.</div>
                </div>
            </div>

            <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save"></i> Save Changes
                </button>
                <a asp-action="Details" asp-route-specId="@Model.SpecId" class="btn btn-outline-secondary">
                    <i class="bi bi-x-circle"></i> Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    // Split comma-separated tags field into indexed Metadata.Tags[n] inputs before submit
    document.querySelector('form')?.addEventListener('submit', function (e) {
        const raw = document.querySelector('[name="Metadata.TagsRaw"]');
        if (!raw) return;
        const tags = raw.value.split(',').map(t => t.trim()).filter(t => t.length > 0);
        raw.disabled = true;  // exclude the raw field from submission
        tags.forEach(function (tag, i) {
            const hidden = document.createElement('input');
            hidden.type = 'hidden';
            hidden.name = `Metadata.Tags[${i}]`;
            hidden.value = tag;
            e.target.appendChild(hidden);
        });
    });
    </script>
}
