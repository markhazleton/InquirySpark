@model InquirySpark.Common.Models.Spec.DecisionSpecDocument
@{
    ViewData["Title"] = $"Edit — {Model.SpecId}";
    var etag = ViewData["ETag"] as string ?? "";
}

<div class="card border-0 shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h2 class="mb-0"><i class="bi bi-pencil"></i> Edit Specification</h2>
        <span class="badge bg-light text-primary"><code>@Model.SpecId</code></span>
    </div>
    <div class="card-body">
        <form asp-action="Edit" asp-route-specId="@Model.SpecId" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="eTag" value="@etag" />
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="SpecId" class="form-label fw-semibold">Spec ID</label>
                    <input asp-for="SpecId" class="form-control" readonly />
                </div>
                <div class="col-md-6">
                    <label asp-for="Version" class="form-label fw-semibold">Version</label>
                    <input asp-for="Version" class="form-control" />
                    <span asp-validation-for="Version" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="CanonicalBaseUrl" class="form-label fw-semibold">Canonical Base URL</label>
                    <input asp-for="CanonicalBaseUrl" class="form-control" />
                    <span asp-validation-for="CanonicalBaseUrl" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="SafetyPreamble" class="form-label fw-semibold">Safety Preamble</label>
                    <textarea asp-for="SafetyPreamble" class="form-control" rows="3"></textarea>
                </div>
            </div>
            <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save"></i> Save Changes
                </button>
                <a asp-action="Details" asp-route-specId="@Model.SpecId" class="btn btn-outline-secondary">
                    <i class="bi bi-x-circle"></i> Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
