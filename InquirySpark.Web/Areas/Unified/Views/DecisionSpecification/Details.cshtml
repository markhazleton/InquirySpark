@model InquirySpark.Common.Models.Spec.DecisionSpecDocument
@{
    ViewData["Title"] = $"Spec — {Model.SpecId}";
    var etag = ViewData["ETag"] as string ?? "";
}

<div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h2 class="mb-0"><i class="bi bi-file-earmark-text"></i> @(Model.Metadata?.Name ?? Model.SpecId)</h2>
        <span class="badge bg-light text-primary ms-2">
            @(string.IsNullOrEmpty(Model.Status) ? "Draft" : Model.Status)
        </span>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Spec ID</dt>
            <dd class="col-sm-9"><code>@Model.SpecId</code></dd>
            <dt class="col-sm-3">Version</dt>
            <dd class="col-sm-9"><span class="badge bg-secondary">@Model.Version</span></dd>
            @if (Model.Metadata is not null)
            {
                <dt class="col-sm-3">Description</dt>
                <dd class="col-sm-9">@Model.Metadata.Description</dd>
                <dt class="col-sm-3">Owner</dt>
                <dd class="col-sm-9">@Model.Metadata.Owner</dd>
                @if (Model.Metadata.Tags.Any())
                {
                    <dt class="col-sm-3">Tags</dt>
                    <dd class="col-sm-9">
                        @foreach (var tag in Model.Metadata.Tags)
                        {
                            <span class="badge bg-info text-dark me-1">@tag</span>
                        }
                    </dd>
                }
                <dt class="col-sm-3">Created</dt>
                <dd class="col-sm-9">@Model.Metadata.CreatedAt.ToString("yyyy-MM-dd HH:mm") by @Model.Metadata.CreatedBy</dd>
                <dt class="col-sm-3">Updated</dt>
                <dd class="col-sm-9">@Model.Metadata.UpdatedAt.ToString("yyyy-MM-dd HH:mm") by @Model.Metadata.UpdatedBy</dd>
            }
        </dl>

        <div class="row g-3 mb-3">
            <div class="col-md-4 text-center">
                <div class="card border-0 bg-light">
                    <div class="card-body">
                        <div class="display-6 fw-bold text-primary">@Model.Traits.Count</div>
                        <div class="text-muted small">Traits</div>
                    </div>
                </div>
            </div>
            <div class="col-md-4 text-center">
                <div class="card border-0 bg-light">
                    <div class="card-body">
                        <div class="display-6 fw-bold text-success">@Model.Outcomes.Count</div>
                        <div class="text-muted small">Outcomes</div>
                    </div>
                </div>
            </div>
            <div class="col-md-4 text-center">
                <div class="card border-0 bg-light">
                    <div class="card-body">
                        <div class="display-6 fw-bold text-info">@Model.ImmediateSelectIf.Count</div>
                        <div class="text-muted small">Immediate Rules</div>
                    </div>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.SafetyPreamble))
        {
            <div class="alert alert-info">
                <strong><i class="bi bi-shield-check"></i> Safety Preamble:</strong> @Model.SafetyPreamble
            </div>
        }

        <!-- Status transition -->
        <div class="card border-0 bg-light mt-3">
            <div class="card-body">
                <h6 class="card-title"><i class="bi bi-arrow-right-circle"></i> Transition Status</h6>
                <form asp-action="TransitionStatus" asp-route-specId="@Model.SpecId" method="post" class="row g-2">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="version" value="@Model.Version" />
                    <div class="col-md-3">
                        <select name="newStatus" class="form-select form-select-sm">
                            <option value="Draft">Draft</option>
                            <option value="Active">Active</option>
                            <option value="Archived">Archived</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <input type="text" name="comment" class="form-control form-control-sm" placeholder="Transition comment…" />
                    </div>
                    <div class="col-md-auto">
                        <button type="submit" class="btn btn-outline-primary btn-sm"><i class="bi bi-arrow-right-circle"></i> Apply</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <div class="card-footer d-flex gap-2">
        <a asp-action="Edit" asp-route-specId="@Model.SpecId" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-pencil"></i> Edit
        </a>
        <a asp-action="Audit" asp-route-specId="@Model.SpecId" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-clock-history"></i> Audit History
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>
</div>
