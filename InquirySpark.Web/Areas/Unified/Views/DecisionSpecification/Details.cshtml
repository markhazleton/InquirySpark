@model InquirySpark.Common.Models.Spec.DecisionSpecDocument
@{
    ViewData["Title"] = $"Spec — {Model.Metadata?.Name ?? Model.SpecId}";
    var etag = ViewData["ETag"] as string ?? "";
    var statusBadge = Model.Status switch
    {
        "Published" => "bg-success",
        "InReview"  => "bg-warning text-dark",
        "Retired"   => "bg-secondary",
        _           => "bg-primary"
    };
}

<div class="row g-3">
    <!-- Left column: overview + traits/outcomes -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h2 class="mb-0">
                    <i class="bi bi-file-earmark-text"></i>
                    @(Model.Metadata?.Name ?? Model.SpecId)
                </h2>
                <span class="badge @statusBadge ms-2">@Model.Status</span>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-3">Spec ID</dt>
                    <dd class="col-sm-9"><code>@Model.SpecId</code></dd>
                    <dt class="col-sm-3">Version</dt>
                    <dd class="col-sm-9"><span class="badge bg-secondary">@Model.Version</span></dd>
                    @if (Model.Metadata is not null)
                    {
                        @if (!string.IsNullOrEmpty(Model.Metadata.Description))
                        {
                            <dt class="col-sm-3">Description</dt>
                            <dd class="col-sm-9">@Model.Metadata.Description</dd>
                        }
                        @if (!string.IsNullOrEmpty(Model.Metadata.Owner))
                        {
                            <dt class="col-sm-3">Owner</dt>
                            <dd class="col-sm-9">@Model.Metadata.Owner</dd>
                        }
                        @if (Model.Metadata.Tags.Any())
                        {
                            <dt class="col-sm-3">Tags</dt>
                            <dd class="col-sm-9">
                                @foreach (var tag in Model.Metadata.Tags)
                                {
                                    <span class="badge bg-info text-dark me-1">@tag</span>
                                }
                            </dd>
                        }
                        <dt class="col-sm-3">Created</dt>
                        <dd class="col-sm-9">
                            @Model.Metadata.CreatedAt.ToString("yyyy-MM-dd HH:mm")
                            @if (!string.IsNullOrEmpty(Model.Metadata.CreatedBy))
                            {
                                <span class="text-muted">by @Model.Metadata.CreatedBy</span>
                            }
                        </dd>
                        <dt class="col-sm-3">Updated</dt>
                        <dd class="col-sm-9">
                            @Model.Metadata.UpdatedAt.ToString("yyyy-MM-dd HH:mm")
                            @if (!string.IsNullOrEmpty(Model.Metadata.UpdatedBy))
                            {
                                <span class="text-muted">by @Model.Metadata.UpdatedBy</span>
                            }
                        </dd>
                    }
                </dl>

                @if (!string.IsNullOrEmpty(Model.SafetyPreamble))
                {
                    <div class="alert alert-info mt-2">
                        <strong><i class="bi bi-shield-check"></i> Safety Preamble:</strong> @Model.SafetyPreamble
                    </div>
                }

                <div class="row g-3 mt-1 text-center">
                    <div class="col-4">
                        <div class="card border-0 bg-light">
                            <div class="card-body py-2">
                                <div class="fs-3 fw-bold text-primary">@Model.Traits.Count</div>
                                <div class="text-muted small">Traits</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="card border-0 bg-light">
                            <div class="card-body py-2">
                                <div class="fs-3 fw-bold text-success">@Model.Outcomes.Count</div>
                                <div class="text-muted small">Outcomes</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="card border-0 bg-light">
                            <div class="card-body py-2">
                                <div class="fs-3 fw-bold text-info">@Model.ImmediateSelectIf.Count</div>
                                <div class="text-muted small">Immediate Rules</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-footer d-flex gap-2">
                <a asp-action="Edit" asp-route-specId="@Model.SpecId" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-pencil"></i> Edit
                </a>
                <a asp-action="Audit" asp-route-specId="@Model.SpecId" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-clock-history"></i> Audit History
                </a>
                <a asp-area="Unified" asp-controller="DecisionConversation" asp-action="Start"
                   asp-route-specId="@Model.SpecId" class="btn btn-outline-success btn-sm">
                    <i class="bi bi-play-circle"></i> Start Conversation
                </a>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm ms-auto">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>
            </div>
        </div>
    </div>

    <!-- Right column: lifecycle controls + quick actions -->
    <div class="col-lg-4">
        <!-- Status transition -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-light">
                <h6 class="mb-0"><i class="bi bi-arrow-right-circle"></i> Lifecycle Controls</h6>
            </div>
            <div class="card-body">
                <p class="small text-muted mb-2">Current status: <span class="badge @statusBadge">@Model.Status</span></p>
                <form asp-action="TransitionStatus" asp-route-specId="@Model.SpecId" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="version" value="@Model.Version" />
                    <div class="mb-2">
                        <label class="form-label small fw-semibold">Transition to</label>
                        <select name="newStatus" class="form-select form-select-sm">
                            <option value="Draft" selected="@(Model.Status == "Draft" ? "selected" : null)">Draft</option>
                            <option value="InReview" selected="@(Model.Status == "InReview" ? "selected" : null)">In Review</option>
                            <option value="Published" selected="@(Model.Status == "Published" ? "selected" : null)">Published</option>
                            <option value="Retired" selected="@(Model.Status == "Retired" ? "selected" : null)">Retired</option>
                        </select>
                    </div>
                    <div class="mb-2">
                        <input type="text" name="comment" class="form-control form-control-sm"
                               placeholder="Transition comment (optional)…" />
                    </div>
                    <button type="submit" class="btn btn-outline-primary btn-sm w-100">
                        <i class="bi bi-arrow-right-circle"></i> Apply Transition
                    </button>
                </form>
            </div>
        </div>

        <!-- Quick actions -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-light">
                <h6 class="mb-0"><i class="bi bi-lightning"></i> Quick Actions</h6>
            </div>
            <div class="card-body d-grid gap-2">
                <a asp-action="Edit" asp-route-specId="@Model.SpecId" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-pencil"></i> Edit Specification
                </a>
                <a asp-area="Unified" asp-controller="DecisionConversation" asp-action="Start"
                   asp-route-specId="@Model.SpecId" class="btn btn-outline-success btn-sm">
                    <i class="bi bi-play-circle"></i> Start Conversation
                </a>
                <a asp-action="Audit" asp-route-specId="@Model.SpecId" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-clock-history"></i> View Audit History
                </a>
                <hr class="my-1" />
                <form asp-action="Delete" asp-route-specId="@Model.SpecId" method="post"
                      onsubmit="return confirm('Archive this specification? This can be restored later.');">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="version" value="@Model.Version" />
                    <input type="hidden" name="eTag" value="@etag" />
                    <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                        <i class="bi bi-archive"></i> Archive Spec
                    </button>
                </form>
            </div>
        </div>

        <!-- Status info -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-light">
                <h6 class="mb-0"><i class="bi bi-info-circle"></i> Status Info</h6>
            </div>
            <div class="card-body small text-muted">
                <dl class="mb-0">
                    <dt>Draft</dt><dd>Work in progress, not yet reviewed.</dd>
                    <dt>In Review</dt><dd>Submitted for stakeholder review.</dd>
                    <dt>Published</dt><dd>Active and available for conversations.</dd>
                    <dt>Retired</dt><dd>No longer in active use.</dd>
                </dl>
            </div>
        </div>
    </div>
</div>
