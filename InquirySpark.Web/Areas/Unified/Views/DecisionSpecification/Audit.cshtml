@model IEnumerable<InquirySpark.Common.Persistence.Repositories.AuditEntry>
@{
    var specId = ViewData["SpecId"] as string ?? "";
    ViewData["Title"] = $"Audit History — {specId}";
}

<div class="card border-0 shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h2 class="mb-0"><i class="bi bi-clock-history"></i> Audit History</h2>
        <code class="text-white">@specId</code>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th><i class="bi bi-calendar"></i> Timestamp</th>
                        <th><i class="bi bi-person"></i> Actor</th>
                        <th><i class="bi bi-play-circle"></i> Action</th>
                        <th><i class="bi bi-chat-text"></i> Summary</th>
                        <th><i class="bi bi-box-arrow-in-right"></i> Source</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in Model.OrderByDescending(e => e.CreatedAt))
                    {
                        <tr>
                            <td class="text-nowrap">@entry.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td>@entry.Actor</td>
                            <td><span class="badge bg-primary">@entry.Action</span></td>
                            <td>@entry.Summary</td>
                            <td><span class="text-muted small">@entry.Source</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer d-flex gap-2">
        <a asp-action="Details" asp-route-specId="@specId" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-eye"></i> View Details
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>
</div>
