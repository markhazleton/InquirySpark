@model InquirySpark.Repository.Database.Company
@{
    ViewData["Title"] = $"Company — {Model.Name}";
}

<div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h2 class="mb-0"><i class="bi bi-building"></i> @Model.Name</h2>
        <code class="text-white">@Model.CompanyCd</code>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Company ID</dt>
            <dd class="col-sm-9">@Model.CompanyId</dd>
            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Name</dd>
            <dt class="col-sm-3">Code</dt>
            <dd class="col-sm-9"><code>@Model.CompanyCd</code></dd>
            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@(Model.CompanyDs ?? "—")</dd>
            <dt class="col-sm-3">Title</dt>
            <dd class="col-sm-9">@Model.Title</dd>
            <dt class="col-sm-3">Theme</dt>
            <dd class="col-sm-9">@Model.Theme</dd>
        </dl>
    </div>
    <div class="card-footer">
        <a asp-action="Companies" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Back to Companies
        </a>
    </div>
</div>
