@model List<InquirySpark.Repository.Database.SiteAppMenu>
@{
    ViewData["Title"] = "Site App Menus";
}

<div class="card border-0 shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h2 class="mb-0"><i class="bi bi-list-ul"></i> Site App Menus</h2>
        <span class="badge bg-light text-primary">@Model.Count menus</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th><i class="bi bi-hash"></i> ID</th>
                        <th><i class="bi bi-app"></i> Site App</th>
                        <th><i class="bi bi-card-text"></i> Menu Text</th>
                        <th><i class="bi bi-link"></i> Target Page</th>
                        <th><i class="bi bi-star"></i> Glyph</th>
                        <th><i class="bi bi-sort-numeric-up"></i> Order</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.SiteAppId</td>
                            <td><strong>@item.MenuText</strong></td>
                            <td><code class="small">@item.TartgetPage</code></td>
                            <td><i class="@item.GlyphName"></i> <span class="text-muted small">@item.GlyphName</span></td>
                            <td>@item.MenuOrder</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer text-muted d-flex justify-content-between align-items-center">
        <span><i class="bi bi-info-circle"></i> Total: @Model.Count menus</span>
        <span><i class="bi bi-lightning"></i> DataTables enabled</span>
    </div>
</div>
