{
  "ConnectionStrings": {
    "ControlSparkUserContextConnection": "Data Source=../data/sqlite/ControlSparkUser.db;Mode=ReadWriteCreate",
    "InquirySparkConnection": "Data Source=../data/sqlite/InquirySpark.db;Mode=ReadOnly"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "InquirySpark.Repository.Services.UnifiedWeb": "Information",
      "InquirySpark.Web": "Information"
    },
    "Console": {
      "IncludeScopes": true,
      "FormatterName": "simple",
      "FormatterOptions": {
        "SingleLine": false,
        "IncludeScopes": true,
        "TimestampFormat": "yyyy-MM-dd HH:mm:ss ",
        "UseUtcTimestamp": true
      }
    }
  },
  "AllowedHosts": "*",
  "DecisionSpecs": {
    "RootPath": "C:\\websites\\InquirySpark\\DecisionSpecs",
    "LegacyConfigPath": "C:\\websites\\InquirySpark\\configurations\\DecisionSpecs",
    "SoftDeleteRetentionDays": 30,
    "IndexFileName": "DecisionSpecIndex.json"
  },
  "ConversationStorage": {
    "Path": "C:\\websites\\InquirySpark\\conversations"
  },
  "OpenAI": {
    "Provider": "OpenAI",
    "ApiKey": "",
    "Model": "gpt-4",
    "MaxTokens": 500,
    "Temperature": 0.7,
    "EnableFallback": true,
    "TimeoutSeconds": 30
  },
  "ClientUi": {
    "BootswatchTheme": "yeti",
    "DataTablesStateSave": true,
    "DataTablesPageLength": 25,
    "DataTablesExportEnabled": true
  },
  "IdentityBridge": {
    "RoleMappings": [
      {
        "SourceApp": "InquirySpark.Admin",
        "SourceRole": "Administrator",
        "UnifiedRole": "Administrator",
        "IsEquivalent": true,
        "Description": "Administrator role is directly equivalent"
      },
      {
        "SourceApp": "InquirySpark.Admin",
        "SourceRole": "Analyst",
        "UnifiedRole": "Analyst",
        "IsEquivalent": true,
        "Description": "Analyst role is directly equivalent"
      },
      {
        "SourceApp": "InquirySpark.Admin",
        "SourceRole": "Operator",
        "UnifiedRole": "Operator",
        "IsEquivalent": true,
        "Description": "Operator role is directly equivalent"
      },
      {
        "SourceApp": "InquirySpark.Admin",
        "SourceRole": "Consultant",
        "UnifiedRole": "Consultant",
        "IsEquivalent": true,
        "Description": "Consultant role is directly equivalent"
      },
      {
        "SourceApp": "InquirySpark.Admin",
        "SourceRole": "Executive",
        "UnifiedRole": "Executive",
        "IsEquivalent": true,
        "Description": "Executive role is directly equivalent"
      }
    ]
  },
